<style>
/* Footer Styles */
.site-footer {
    background: #111;
    color: #fff;
    padding: 40px 0 20px 0;
    font-size: 14px;
    line-height: 1.6;
}

.site-footer h5 {
    font-weight: bold;
    margin-bottom: 15px;
}

.site-footer a {
    color: #ccc;
    text-decoration: none;
    transition: 0.3s;
}

.site-footer a:hover {
    color: #00c6ff;
    text-decoration: none;
}

.footer-links {
    list-style: none;
    padding: 0;
}

.footer-links li {
    margin-bottom: 8px;
}

.social-icons a {
    display: inline-block;
    width: 35px;
    height: 35px;
    line-height: 35px;
    text-align: center;
    margin-right: 8px;
    border-radius: 50%;
    background: #222;
    color: #fff;
    transition: 0.3s;
}

.social-icons a:hover {
    background: #00c6ff;
    color: #111;
}

hr {
    border-color: #333;
    margin: 20px 0;
}

.text-center {
    text-align: center;
}

/* Responsive */
@media (max-width: 768px) {
    .social-icons a {
        width: 30px;
        height: 30px;
        line-height: 30px;
        margin-right: 6px;
    }
}
</style>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
<footer class="site-footer">
    <div class="container">
        <div class="row">

            <!-- About Section -->
            <div class="col-md-4">
                <h5>About Blogify</h5>
                <p>Your daily dose of blogs, tech, and life tips. Stay updated with the latest posts!</p>
            </div>

            <!-- Quick Links -->
            <div class="col-md-4">
                <h5>Quick Links</h5>
                <ul class="footer-links">
                    <li><a href="/">Home</a></li>
                    <li><a href="/blog/add">Add Blog</a></li>
                    <li><a href="/user/signin">Sign In</a></li>
                    <li><a href="/user/signup">Sign Up</a></li>
                </ul>
            </div>

            <!-- Social Media -->
            <div class="col-md-4">
                <h5>Follow Us</h5>
                <div class="social-icons">
                    <a href="#" target="blank"><i class="fa-brands fa-linkedin"></i></i></a>
                    <a href="#" target="_blank"><i class="fab fa-twitter"></i></a>
                    <a href="#" target="_blank"><i class="fab fa-instagram"></i></a>
                    <a href="#" target="_blank"><i class="fab fa-linkedin-in"></i></a>
                </div>
            </div>

        </div>

        <hr>

        <div class="row">
            <div class="col-md-12 text-center">
                <p>&copy; <%= new Date().getFullYear() %> Blogify. All rights reserved.</p>
            </div>
        </div>
    </div>
</footer>