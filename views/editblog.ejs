<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head') %>
    <title>Edit Blog</title>
</head>
<body>

<%- include('./partials/nav') %>

<div class="container mt-4">

    <h3>Edit Blog ✏️</h3>

    <form action="/blog/edit/<%= blog._id %>" method="POST">

        <!-- Title -->
        <div class="mb-3">
            <label>Title</label>
            <input type="text" name="title" 
                   value="<%= blog.title %>" 
                   class="form-control">
        </div>

        <!-- Body -->
        <div class="mb-3">
            <label>Body</label>
            <textarea name="body" class="form-control" rows="5"><%= blog.body %></textarea>
        </div>

        <!-- Tags -->
        <div class="mb-3">
            <label>Tags (comma separated)</label>
            <input type="text" name="tags" 
                   value="<%= blog.tags.join(',') %>" 
                   class="form-control">
        </div>

        <!-- Buttons -->
        <button class="btn btn-success">Update Blog</button>
        <a href="/" class="btn btn-secondary">Cancel</a>

    </form>

</div>

<%- include('./partials/scripts') %>

</body>
</html>